{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Diagnosis": {
      "title": "Diagnosis",
      "description": "Music diagnosis request and result",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "musicUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "analyzing", "completed"] },
        "result": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "musicUrl", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents"
    },
    "/diagnoses/{diagnosisId}": {
      "schema": "Diagnosis",
      "description": "Diagnosis requests"
    }
  }
}
